{
  "info": {
    "name": "UFO Reporting System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "report_id",
      "value": "1"
    },
    {
      "key": "category_id",
      "value": "1"
    },
    {
      "key": "user_id",
      "value": "1"
    },
    {
      "key": "image_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Regisztráció",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teszt User\",\n  \"email\": \"teszt@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Bejelentkezés (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@ufo.hu\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Bejelentkezés (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('admin_token', json.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ufo.hu\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Bejelentkezett user adatai",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/user", "host": ["{{base_url}}"], "path": ["user"] }
          }
        },
        {
          "name": "Kijelentkezés",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] }
          }
        }
      ]
    },
    {
      "name": "Bejelentések",
      "item": [
        {
          "name": "Összes bejelentés (lista)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/reports?sort_by=created_at&sort_dir=desc&per_page=10",
              "host": ["{{base_url}}"],
              "path": ["reports"],
              "query": [
                { "key": "sort_by", "value": "created_at" },
                { "key": "sort_dir", "value": "desc" },
                { "key": "per_page", "value": "10" },
                { "key": "category_id", "value": "1", "disabled": true },
                { "key": "status", "value": "approved", "disabled": true },
                { "key": "date_from", "value": "2025-01-01", "disabled": true },
                { "key": "date_to", "value": "2025-12-31", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Bejelentés részletei",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/reports/{{report_id}}", "host": ["{{base_url}}"], "path": ["reports", "{{report_id}}"] }
          }
        },
        {
          "name": "Új bejelentés létrehozása",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('report_id', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/reports", "host": ["{{base_url}}"], "path": ["reports"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": 1,\n  \"title\": \"Fura fény Budapest felett\",\n  \"description\": \"Tegnap este 23:00 körül egy pulsáló narancssárga fényt láttam a Duna felett lebegni. Kb. 10 percig volt látható, majd hirtelen eltűnt.\",\n  \"latitude\": 47.4979,\n  \"longitude\": 19.0402,\n  \"date\": \"2026-03-21\",\n  \"witnesses\": 2\n}"
            }
          }
        },
        {
          "name": "Bejelentés módosítása",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/reports/{{report_id}}", "host": ["{{base_url}}"], "path": ["reports", "{{report_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Módosított cím\",\n  \"witnesses\": 5\n}"
            }
          }
        },
        {
          "name": "Bejelentés törlése",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/reports/{{report_id}}", "host": ["{{base_url}}"], "path": ["reports", "{{report_id}}"] }
          }
        },
        {
          "name": "Bejelentések térképhez",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/map/reports", "host": ["{{base_url}}"], "path": ["map", "reports"] }
          }
        }
      ]
    },
    {
      "name": "Képek",
      "item": [
        {
          "name": "Bejelentés képeinek listája",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/reports/{{report_id}}/images", "host": ["{{base_url}}"], "path": ["reports", "{{report_id}}", "images"] }
          }
        },
        {
          "name": "Kép feltöltése",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/reports/{{report_id}}/images", "host": ["{{base_url}}"], "path": ["reports", "{{report_id}}", "images"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "images[]", "type": "file", "src": "/path/to/image.jpg", "description": "Tölts be egy képet (max 5MB, jpg/png/gif/webp)" }
              ]
            }
          }
        },
        {
          "name": "Kép törlése",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/images/{{image_id}}", "host": ["{{base_url}}"], "path": ["images", "{{image_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Szavazás",
      "item": [
        {
          "name": "Hitelessági pontszám",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/reports/{{report_id}}/credibility", "host": ["{{base_url}}"], "path": ["reports", "{{report_id}}", "credibility"] }
          }
        },
        {
          "name": "Szavazás (up)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/reports/{{report_id}}/vote", "host": ["{{base_url}}"], "path": ["reports", "{{report_id}}", "vote"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vote_type\": \"up\"\n}"
            }
          }
        },
        {
          "name": "Szavazás (down)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/reports/{{report_id}}/vote", "host": ["{{base_url}}"], "path": ["reports", "{{report_id}}", "vote"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vote_type\": \"down\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Kategóriák",
      "item": [
        {
          "name": "Összes kategória",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/categories", "host": ["{{base_url}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Kategória részletei",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/categories/{{category_id}}", "host": ["{{base_url}}"], "path": ["categories", "{{category_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Profil",
      "item": [
        {
          "name": "Profil megtekintése",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/profile", "host": ["{{base_url}}"], "path": ["profile"] }
          }
        },
        {
          "name": "Profil módosítása",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/profile", "host": ["{{base_url}}"], "path": ["profile"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Új Név\"\n}"
            }
          }
        },
        {
          "name": "Felhasználó bejelentései",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/users/{{user_id}}/reports", "host": ["{{base_url}}"], "path": ["users", "{{user_id}}", "reports"] }
          }
        }
      ]
    },
    {
      "name": "Statisztikák",
      "item": [
        {
          "name": "Általános statisztikák",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/statistics", "host": ["{{base_url}}"], "path": ["statistics"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Bejelentések",
          "item": [
            {
              "name": "Összes bejelentés (admin)",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" }
                ],
                "url": {
                  "raw": "{{base_url}}/admin/reports?status=pending",
                  "host": ["{{base_url}}"],
                  "path": ["admin", "reports"],
                  "query": [
                    { "key": "status", "value": "pending", "disabled": true }
                  ]
                }
              }
            },
            {
              "name": "Bejelentés jóváhagyása",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" }
                ],
                "url": { "raw": "{{base_url}}/admin/reports/{{report_id}}/approve", "host": ["{{base_url}}"], "path": ["admin", "reports", "{{report_id}}", "approve"] }
              }
            },
            {
              "name": "Bejelentés elutasítása",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" }
                ],
                "url": { "raw": "{{base_url}}/admin/reports/{{report_id}}/reject", "host": ["{{base_url}}"], "path": ["admin", "reports", "{{report_id}}", "reject"] }
              }
            },
            {
              "name": "Bejelentés törlése (admin)",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" }
                ],
                "url": { "raw": "{{base_url}}/admin/reports/{{report_id}}", "host": ["{{base_url}}"], "path": ["admin", "reports", "{{report_id}}"] }
              }
            }
          ]
        },
        {
          "name": "Felhasználók",
          "item": [
            {
              "name": "Összes felhasználó",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" }
                ],
                "url": {
                  "raw": "{{base_url}}/admin/users",
                  "host": ["{{base_url}}"],
                  "path": ["admin", "users"],
                  "query": [
                    { "key": "search", "value": "", "disabled": true }
                  ]
                }
              }
            },
            {
              "name": "Felhasználó tiltása",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" }
                ],
                "url": { "raw": "{{base_url}}/admin/users/{{user_id}}/ban", "host": ["{{base_url}}"], "path": ["admin", "users", "{{user_id}}", "ban"] }
              }
            },
            {
              "name": "Tiltás feloldása",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" }
                ],
                "url": { "raw": "{{base_url}}/admin/users/{{user_id}}/unban", "host": ["{{base_url}}"], "path": ["admin", "users", "{{user_id}}", "unban"] }
              }
            }
          ]
        },
        {
          "name": "Kategóriák",
          "item": [
            {
              "name": "Új kategória (admin)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" }
                ],
                "url": { "raw": "{{base_url}}/admin/categories", "host": ["{{base_url}}"], "path": ["admin", "categories"] },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Új Kategória\",\n  \"description\": \"Kategória leírása\"\n}"
                }
              }
            },
            {
              "name": "Kategória módosítása (admin)",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" }
                ],
                "url": { "raw": "{{base_url}}/admin/categories/{{category_id}}", "host": ["{{base_url}}"], "path": ["admin", "categories", "{{category_id}}"] },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Módosított Név\",\n  \"description\": \"Módosított leírás\"\n}"
                }
              }
            },
            {
              "name": "Kategória törlése (admin)",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" }
                ],
                "url": { "raw": "{{base_url}}/admin/categories/{{category_id}}", "host": ["{{base_url}}"], "path": ["admin", "categories", "{{category_id}}"] }
              }
            }
          ]
        },
        {
          "name": "Admin statisztikák",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/admin/statistics", "host": ["{{base_url}}"], "path": ["admin", "statistics"] }
          }
        }
      ]
    }
  ]
}
